# ===========================================
# PRODUCTION ENVIRONMENT TEMPLATE
# ===========================================
# Copy this file to .env.production and fill in your actual values
# NEVER commit production credentials to version control!
#
# Usage:
#   cp .env.production.template .env.production
#   # Edit .env.production with your actual values
#   docker-compose --env-file .env.production up -d
# ===========================================

# ===========================================
# DATABASE CONFIGURATION [REQUIRED]
# ===========================================
# For Neon PostgreSQL (Render):
#   Get connection string from Neon console
#   Format: jdbc:postgresql://ep-xxx.c-4.us-east-1.aws.neon.tech/neondb?sslmode=require
#
# For AWS RDS PostgreSQL:
#   Format: jdbc:postgresql://your-rds-endpoint:5432/gymstore?sslmode=require
#
# For other cloud providers:
#   Use full JDBC URL with sslmode=require
DATABASE_URL=jdbc:postgresql://your-database-host:5432/gymstore?sslmode=require
DATABASE_USERNAME=your_database_username
DATABASE_PASSWORD=your_secure_database_password

# ===========================================
# JWT SECRET [REQUIRED]
# ===========================================
# Generate a strong random secret (minimum 32 characters):
#   openssl rand -base64 64
# Example output: "aBcDeFgHiJkLmNoPqRsTuVwXyZ0123456789+/ABCDEFGHIJKLMNOPQRSTUVWXYZ=="
JWT_SECRET=YOUR_VERY_LONG_AND_SECURE_JWT_SECRET_KEY_GENERATED_WITH_OPENSSL

# ===========================================
# EMAIL CONFIGURATION (SMTP) [REQUIRED]
# ===========================================
# For Gmail:
#   1. Enable 2-factor authentication on your Google account
#   2. Generate an App Password: https://myaccount.google.com/apppasswords
#   3. Use the App Password below (NOT your regular Gmail password)
#
# For other SMTP providers (SendGrid, Mailgun, etc.):
#   Update SPRING_MAIL_HOST and SPRING_MAIL_PORT accordingly
SPRING_MAIL_HOST=smtp.gmail.com
SPRING_MAIL_PORT=587
SPRING_MAIL_USERNAME=your-email@gmail.com
SPRING_MAIL_PASSWORD=your_gmail_app_specific_password

# ===========================================
# FRONTEND URL (CORS) [REQUIRED]
# ===========================================
# Comma-separated list of ALL your production frontend domains
# Include both with and without 'www' if applicable
# Example: https://gymstore.com,https://www.gymstore.com
FRONTEND_URL=https://lennoxgymstore1.netlify.app

# ===========================================
# FILE UPLOAD CONFIGURATION
# ===========================================
# For Docker deployment, use an absolute path inside the container
# For persistent storage, mount a volume to this path
FILE_UPLOAD_DIR=/app/uploads

# ===========================================
# HIBERNATE SETTINGS
# ===========================================
# IMPORTANT: Set to 'validate' or 'none' in production!
# 'update' can cause performance issues and unintended schema changes
# Options: none | validate | update | create | create-drop
SPRING_JPA_HIBERNATE_DDL_AUTO=validate
SPRING_JPA_SHOW_SQL=false

# ===========================================
# LOGGING CONFIGURATION
# ===========================================
# Set to INFO or WARN in production (DEBUG is too verbose)
LOG_LEVEL=INFO
LOG_LEVEL_APP=INFO
LOG_LEVEL_SPRING=INFO
LOG_LEVEL_SECURITY=INFO
LOG_LEVEL_HIBERNATE=WARN

# ===========================================
# ADDITIONAL SECURITY SETTINGS (Optional)
# ===========================================
# JWT expiration in milliseconds (default: 86400000 = 24 hours)
# JWT_EXPIRATION=86400000

# ===========================================
# DEPLOYMENT NOTES
# ===========================================
# 1. Generate JWT secret: openssl rand -base64 64
# 2. For Gmail: Use App Password, not regular password
# 3. Set HIBERNATE_DDL_AUTO to 'validate' in production
# 4. Mount volume for file uploads: -v /host/path:/app/uploads
# 5. Use environment variables or secrets management in production
# 6. Never commit this file with real credentials!
# 7. Add .env.production to .gitignore
# 8. Rotate secrets regularly (JWT, database passwords, etc.)