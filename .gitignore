# ===========================================
# Global .gitignore for E-commerce Gym Store
# ===========================================

# Environment files (NEVER commit these!)
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
.env.production
*.env

# IDE and Editor files
.vscode/
.idea/
*.swp
*.swo
*~

# Operating System files
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# Build directories
target/
build/
dist/
node_modules/

# Log files
*.log
logs/

# Temporary files
tmp/
temp/
*.tmp

# Uploads directory (product images)
uploads/
Backend/uploads/

# Compiled files
*.class
*.jar
*.war
*.ear

# Maven
.mvn/timing.properties
.mvn/wrapper/maven-wrapper.jar

# Gradle
.gradle/
build/

# Testing
coverage/
.nyc_output/

# Dependency directories
vendor/
bower_components/

# Database files (if using local SQLite)
*.db
*.sqlite
*.sqlite3

# Cache files
.cache/
.eslintcache
.stylelintcache

# Test artifacts
test-results/
junit/

# Generated files
*.generated.js
*.generated.css

# Backup files
*.bak
*.backup