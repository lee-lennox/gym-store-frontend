# Frontend Environment Configuration
# ===========================================
# This file configures the API endpoint for the frontend

# For local development with Docker Compose:
# The nginx proxy handles /api requests, so we use relative path
REACT_APP_API_URL=/api

# For local development without Docker (direct backend connection):
# REACT_APP_API_URL=http://localhost:8080/api

# For production deployment (Netlify frontend + Render backend):
# REACT_APP_API_URL=https://gymstore-5ni9.onrender.com/api