# ===========================================
# Environment Variables for GymStore Backend
# ===========================================
# This file is used for local development with Docker Compose
# For production deployment, copy this file and update values
#
# IMPORTANT: Never commit production credentials!
# Add .env to .gitignore for production environments.
# ===========================================

# ===========================================
# Database Configuration
# ===========================================
# For Docker Compose local development:
DATABASE_URL=jdbc:postgresql://postgres:5432/gymstore
DATABASE_USERNAME=postgres
DATABASE_PASSWORD=postgres

# For production (Neon PostgreSQL on Render):
# DATABASE_URL=jdbc:postgresql://ep-xxx.c-4.us-east-1.aws.neon.tech/neondb?sslmode=require
# DATABASE_USERNAME=neondb_owner
# DATABASE_PASSWORD=your_neon_password

# ===========================================
# JWT Secret
# ===========================================
# Generate a strong secret: openssl rand -base64 64
# Local development default (NOT for production!)
JWT_SECRET=DevSecretKeyForJWTTokenGenerationMustBeAtLeast256BitsLongForHS256Algorithm

# ===========================================
# Email Configuration (SMTP)
# ===========================================
SPRING_MAIL_HOST=smtp.gmail.com
SPRING_MAIL_PORT=587
# Use your actual email and app-specific password
SPRING_MAIL_USERNAME=dev@gmail.com
SPRING_MAIL_PASSWORD=dev-password

# ===========================================
# Frontend URL (CORS)
# ===========================================
# Comma-separated list of allowed origins
FRONTEND_URL=http://localhost:3000,http://localhost:5173,https://lennoxgymstore1.netlify.app

# ===========================================
# File Upload Configuration
# ===========================================
FILE_UPLOAD_DIR=uploads

# ===========================================
# Hibernate Settings
# ===========================================
# For production, set to 'validate' or 'none'
SPRING_JPA_HIBERNATE_DDL_AUTO=update
SPRING_JPA_SHOW_SQL=false

# ===========================================
# Logging Configuration
# ===========================================
LOG_LEVEL=INFO
LOG_LEVEL_APP=INFO
LOG_LEVEL_SPRING=INFO
LOG_LEVEL_SECURITY=INFO
LOG_LEVEL_HIBERNATE=INFO