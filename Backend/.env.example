# ===========================================
# Environment Variables for Production Profile
# ===========================================
# Copy this file to .env and fill in your values.
# Activate the 'prod' profile when running the application.
#
# Usage:
#   - Docker: docker run -e SPRING_PROFILES_ACTIVE=prod --env-file .env ...
#   - Command line: java -jar app.jar --spring.profiles.active=prod
#   - Environment variable: export SPRING_PROFILES_ACTIVE=prod
# ===========================================

# --- Database Configuration ---
DATABASE_URL=jdbc:postgresql://your-database-host:5432/gymstore
DATABASE_USERNAME=postgres
DATABASE_PASSWORD=your_secure_database_password

# --- JWT Secret ---
# MUST be at least 256 bits (32 characters) for HS256 algorithm
# Generate a strong random secret:
#   openssl rand -base64 64
JWT_SECRET=YourSuperSecretKeyForJWTTokenGenerationMustBeAtLeast256BitsLongForHS256Algorithm

# --- Email Configuration (Gmail SMTP) ---
SPRING_MAIL_USERNAME=your-email@gmail.com
SPRING_MAIL_PASSWORD=your-app-specific-password

# --- Frontend URL for CORS ---
# Comma-separated list of allowed origins
# Production: use your actual domain(s)
FRONTEND_URL=https://lennoxgymstore1.netlify.app

# --- Spring Profile ---
# Set to 'prod' for production deployments
SPRING_PROFILES_ACTIVE=prod