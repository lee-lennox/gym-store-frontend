# ===========================================
# Environment Variables for GymStore Backend
# ===========================================
# Copy this file to .env and fill in your values.
#
# Usage:
#   - Docker: docker run --env-file .env ...
#   - Docker Compose: Automatically loads .env file
#   - Local: Export variables or use a tool like dotenv
#
# All variables have safe defaults for local development.
# For production, OVERRIDE all variables marked [REQUIRED].
# ===========================================

# ===========================================
# Database Configuration [REQUIRED for production]
# ===========================================
# PostgreSQL connection URL
# 
# For Neon PostgreSQL (Render deployment):
#   Use the connection string from Neon console:
#   postgresql://neondb_owner:npg_XXX@ep-XXX.c-4.us-east-1.aws.neon.tech/neondb?sslmode=require
#
# For local development:
#   jdbc:postgresql://localhost:5432/gymstore
#
# For other cloud providers:
#   Use the full JDBC URL with sslmode=require
DATABASE_URL=postgresql://neondb_owner:your_password@ep-XXX.c-4.us-east-1.aws.neon.tech/neondb?sslmode=require

# Database username (optional if using DATABASE_URL with embedded credentials)
# Neon: neondb_owner
DATABASE_USERNAME=neondb_owner

# Database password (optional if using DATABASE_URL with embedded credentials)
# [REQUIRED] Set your Neon database password
DATABASE_PASSWORD=your_neon_database_password

# SSL Mode for cloud databases (default: prefer)
# Options: disable, allow, prefer, require, verify-ca, verify-full
# - Local development: disable or prefer
# - Neon/Render/AWS RDS: require
DATABASE_SSL_MODE=prefer

# ===========================================
# JWT Secret [REQUIRED for production]
# ===========================================
# MUST be at least 256 bits (32 characters) for HS256 algorithm
# Generate a strong random secret:
#   openssl rand -base64 64
# Local default: DevSecretKeyForJWTTokenGenerationMustBeAtLeast256BitsLongForHS256Algorithm
# [REQUIRED] Override with a strong random value in production
JWT_SECRET=YourSuperSecretKeyForJWTTokenGenerationMustBeAtLeast256BitsLongForHS256Algorithm

# ===========================================
# Email Configuration (SMTP)
# ===========================================
# SMTP host
# Local default: smtp.gmail.com
SPRING_MAIL_HOST=smtp.gmail.com

# SMTP port
# Local default: 587
SPRING_MAIL_PORT=587

# Email username (Gmail address)
# Local default: dev@gmail.com
# [REQUIRED] Set your actual email in production
SPRING_MAIL_USERNAME=your-email@gmail.com

# Email password (App-specific password for Gmail)
# Local default: dev-password
# [REQUIRED] Set your app-specific password in production
SPRING_MAIL_PASSWORD=your-app-specific-password

# SMTP authentication (default: true)
SPRING_MAIL_AUTH=true

# STARTTLS (default: true)
SPRING_MAIL_STARTTLS=true
SPRING_MAIL_STARTTLS_REQUIRED=true

# SMTP timeouts (milliseconds)
SPRING_MAIL_CONNECTION_TIMEOUT=5000
SPRING_MAIL_TIMEOUT=5000
SPRING_MAIL_WRITETIMEOUT=5000

# ===========================================
# Frontend URL (CORS & Links)
# ===========================================
# Comma-separated list of allowed origins for CORS
# Also used for password reset links and other frontend URLs
# Local default: http://localhost:5173,http://localhost:3000,http://127.0.0.1:5173,http://127.0.0.1:3000
# [REQUIRED] Set to your production domain(s)
FRONTEND_URL=https://lennoxgymstore1.netlify.app

# ===========================================
# Logging Configuration
# ===========================================
# Root log level (default: INFO)
# Options: DEBUG, INFO, WARN, ERROR
LOG_LEVEL=INFO

# Application-specific log levels (default: INFO)
LOG_LEVEL_APP=INFO
LOG_LEVEL_SPRING=INFO
LOG_LEVEL_SECURITY=INFO
LOG_LEVEL_HIBERNATE=INFO

# ===========================================
# JPA/Hibernate Settings
# ===========================================
# Hibernate DDL mode (default: update)
# Options: none, validate, update, create, create-drop
# [REQUIRED] Set to 'validate' or 'none' in production
SPRING_JPA_HIBERNATE_DDL_AUTO=update

# Show SQL (default: false)
SPRING_JPA_SHOW_SQL=false

# Format SQL (default: false)
HIBERNATE_FORMAT_SQL=false

# ===========================================
# Spring Profile (Optional)
# ===========================================
# No profile-specific configuration files are used.
# All configuration is in application.properties with env var overrides.
# This variable is kept for compatibility if needed.
# SPRING_PROFILES_ACTIVE=